# Maven build output — never commit compiled artifacts
target/
*.jar
*.war
*.class

# macOS
.DS_Store

# IDE files
.idea/
.vscode/
*.iml

# Terraform working directories
**/.terraform/
**/.terraform.lock.hcl

# Terraform state — use remote state (bootstrap/)
*.tfstate
*.tfstate.backup

# Terraform variable files — may contain secrets
*.tfvars
*.tfvars.json

# Crash logs
crash.log
